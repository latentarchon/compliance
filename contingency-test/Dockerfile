FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /contingency-test ./cmd/contingency-test

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /contingency-test /contingency-test
ENTRYPOINT ["/contingency-test"]
